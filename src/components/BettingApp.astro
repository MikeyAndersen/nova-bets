---
// BettingApp — fetches odds, renders match cards, manages bet slip
---

<section id="bettingApp">
  <div id="matchesContainer">
    <div class="loading-state">
      <div class="spinner"></div>
      <span>Henter kampe…</span>
    </div>
  </div>
  <p id="apiQuota" class="api-quota"></p>
</section>

<!-- Bet slip backdrop -->
<div class="slip-backdrop" id="slipBackdrop"></div>

<!-- Bet slip panel -->
<aside class="bet-slip" id="betSlip" aria-hidden="true" aria-label="Bet slip">
  <div class="slip-head">
    <span class="slip-title">Bet Slip</span>
    <button class="slip-close" id="slipClose" aria-label="Luk">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="slip-body">
    <div class="slip-match-name" id="slipMatchName"></div>
    <div class="slip-league" id="slipLeague"></div>
    <div class="slip-selection-row">
      <span class="slip-sel-label" id="slipSelLabel"></span>
      <span class="slip-odds-badge" id="slipOddsBadge"></span>
    </div>

    <div class="stake-field">
      <label for="stakeInput" class="stake-label">Indsats</label>
      <div class="stake-wrap">
        <input
          type="number"
          id="stakeInput"
          class="stake-input"
          placeholder="0"
          min="10"
          step="10"
        />
        <span class="stake-kr">kr</span>
      </div>
    </div>

    <div class="potential-row">
      <span class="potential-label">Mulig gevinst</span>
      <span class="potential-val" id="potentialWin">0 kr</span>
    </div>
  </div>

  <div class="slip-foot">
    <button class="btn-cancel" id="slipCancel">Annuller</button>
    <button class="btn-place" id="slipPlace">Placer indsats</button>
  </div>
</aside>

<style is:global>
  /* ── Shared loading / error / empty ── */
  .loading-state,
  .error-state,
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 5rem 2rem;
    color: var(--muted);
    text-align: center;
    font-size: 0.95rem;
  }

  .spinner {
    width: 30px;
    height: 30px;
    border: 3px solid rgba(255,255,255,0.08);
    border-top-color: var(--green);
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .btn-retry {
    background: var(--green);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.55rem 1.2rem;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font);
    transition: background 0.18s;
  }
  .btn-retry:hover { background: #00784f; }

  .api-quota {
    margin-top: 1.5rem;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.2);
    text-align: right;
  }

  /* ── League sections ── */
  #matchesContainer {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .league-section { }

  .league-header {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mint);
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.6rem;
  }

  .match-list {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  /* ── Match card ── */
  .match-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.9rem 1.1rem;
    transition: border-color 0.18s;
  }
  .match-card:hover { border-color: rgba(255,255,255,0.14); }

  .match-time {
    font-size: 0.72rem;
    color: var(--muted);
    margin-bottom: 0.65rem;
    text-transform: capitalize;
  }

  .match-odds-row {
    display: grid;
    grid-template-columns: 1fr 72px 1fr;
    gap: 0.45rem;
    align-items: stretch;
  }

  /* ── Odds buttons ── */
  .odds-btn {
    background: rgba(0, 100, 66, 0.12);
    border: 1px solid rgba(0, 100, 66, 0.28);
    border-radius: 7px;
    padding: 0.55rem 0.4rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    min-width: 0;
  }
  .odds-btn:hover {
    background: rgba(0, 100, 66, 0.25);
    border-color: rgba(0, 100, 66, 0.55);
  }
  .odds-btn.selected {
    background: rgba(242, 199, 68, 0.12);
    border-color: var(--gold);
  }
  .odds-btn.selected .odds-val { color: var(--gold); }

  .match-bookmaker {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.25);
    text-align: right;
    margin-top: 0.4rem;
  }

  .odds-name {
    font-size: 0.72rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    text-align: center;
    line-height: 1.2;
  }
  .odds-val {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
  }

  /* ── Bet slip ── */
  .slip-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 200;
    animation: fadeIn 0.2s ease;
  }
  .slip-backdrop.active { display: block; }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .bet-slip {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 340px;
    background: var(--surface);
    border-left: 1px solid var(--border);
    z-index: 201;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .bet-slip.open { transform: translateX(0); }

  .slip-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.4rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .slip-title {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .slip-close {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .slip-close:hover { color: var(--text); }

  .slip-body {
    flex: 1;
    padding: 1.4rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .slip-match-name {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.35;
    color: var(--text);
  }
  .slip-league {
    font-size: 0.72rem;
    color: var(--mint);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: -0.6rem;
  }

  .slip-selection-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface2);
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
  }
  .slip-sel-label {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .slip-odds-badge {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--gold);
    letter-spacing: -0.02em;
  }

  .stake-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .stake-label {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 500;
  }
  .stake-wrap {
    position: relative;
  }
  .stake-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 2.8rem 0.75rem 0.9rem;
    color: var(--text);
    font-size: 1.1rem;
    font-weight: 600;
    outline: none;
    transition: border-color 0.18s;
    font-family: var(--font);
    -moz-appearance: textfield;
  }
  .stake-input::-webkit-inner-spin-button,
  .stake-input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .stake-input:focus { border-color: var(--green); }
  .stake-input.shake {
    animation: shake 0.38s ease;
    border-color: #e05555 !important;
  }
  @keyframes shake {
    0%,100% { transform: translateX(0); }
    20%,60%  { transform: translateX(-5px); }
    40%,80%  { transform: translateX(5px); }
  }
  .stake-kr {
    position: absolute;
    right: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.82rem;
    color: var(--muted);
    pointer-events: none;
  }

  .potential-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--surface2);
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
  }
  .potential-label { font-size: 0.82rem; color: var(--muted); }
  .potential-val {
    font-size: 1rem;
    font-weight: 700;
    color: var(--mint);
  }

  .slip-foot {
    display: flex;
    gap: 0.65rem;
    padding: 1.1rem 1.4rem;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }
  .btn-cancel {
    flex: 1;
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 8px;
    padding: 0.72rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-family: var(--font);
    transition: border-color 0.18s, color 0.18s;
  }
  .btn-cancel:hover { border-color: rgba(255,255,255,0.2); color: var(--text); }

  .btn-place {
    flex: 2;
    background: var(--green);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.72rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: var(--font);
    transition: background 0.18s;
  }
  .btn-place:hover { background: #00784f; }

  /* ── Mobile: bottom sheet ── */
  @media (max-width: 620px) {
    .bet-slip {
      top: auto;
      left: 0;
      right: 0;
      width: 100%;
      height: 88vh;
      border-left: none;
      border-top: 1px solid var(--border);
      border-radius: 16px 16px 0 0;
      transform: translateY(100%);
    }
    .bet-slip.open { transform: translateY(0); }

    .match-odds-row {
      grid-template-columns: 1fr 64px 1fr;
      gap: 0.35rem;
    }
  }
</style>

<script is:inline>
(function () {
  var LEAGUES = [39, 2, 3, 848, 78, 79, 140, 135, 61, 119, 88, 94];

  var LEAGUE_NAMES = {
    39: 'Premier League',    2: 'Champions League',
    3: 'Europa League',      848: 'Conference League',
    78: 'Bundesliga',        79: '2. Bundesliga',
    140: 'La Liga',          135: 'Serie A',
    61: 'Ligue 1',           119: 'Superliga',
    88: 'Eredivisie',        94: 'Primeira Liga'
  };

  var APIF_KEY  = '66466592dc0296d8fdc06408bfeecf40';
  var APIF_BASE = 'https://v3.football.api-sports.io';
  var PROXY     = 'https://corsproxy.io/?url=';
  var CACHE_KEY      = 'nb_odds_cache';
  var CACHE_TIME_KEY = 'nb_odds_cache_time';
  var CACHE_TTL_MS   = 1 * 60 * 1000;

  var matchStore = {};
  var current = null;

  /* ── Utilities ── */
  function fmtKr(n) {
    return new Intl.NumberFormat('da-DK').format(Math.round(n)) + ' kr';
  }
  function fmtDate(iso) {
    return new Intl.DateTimeFormat('da-DK', {
      timeZone: 'Europe/Copenhagen',
      weekday: 'short', day: 'numeric', month: 'short',
      hour: '2-digit', minute: '2-digit'
    }).format(new Date(iso));
  }
  function esc(s) {
    return String(s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
  function todayDateStr() {
    var n = new Date();
    return n.getUTCFullYear() + '-' +
      String(n.getUTCMonth() + 1).padStart(2, '0') + '-' +
      String(n.getUTCDate()).padStart(2, '0');
  }
  function futureDateStr(daysAhead) {
    var n = new Date(Date.now() + daysAhead * 24 * 60 * 60 * 1000);
    return n.getUTCFullYear() + '-' +
      String(n.getUTCMonth() + 1).padStart(2, '0') + '-' +
      String(n.getUTCDate()).padStart(2, '0');
  }
  function selectionLabel(outcome, homeTeam, awayTeam) {
    if (outcome === 'Draw') return 'Uafgjort';
    if (outcome === homeTeam) return homeTeam + ' vinder';
    return awayTeam + ' vinder';
  }

  /* ── Normalise: API-Football fixture + odds → common shape ── */
  function normalizeApifMatch(fixture, oddsResp, leagueName) {
    var bookmakers = oddsResp && oddsResp[0] && oddsResp[0].bookmakers || [];
    var bm = bookmakers.find(function(b) { return b.id === 8; }); // bet365
    if (!bm) return null;
    var matchWinner = (bm.bets || []).find(function(b) {
      return b.id === 1 || b.name === 'Match Winner';
    });
    if (!matchWinner) return null;
    var vals = matchWinner.values || [];
    var home = vals.find(function(v) { return v.value === 'Home'; });
    var draw = vals.find(function(v) { return v.value === 'Draw'; });
    var away = vals.find(function(v) { return v.value === 'Away'; });
    if (!home || !draw || !away) return null;
    return {
      id: 'apif_' + fixture.fixture.id,
      leagueName: leagueName,
      homeTeam: fixture.teams.home.name,
      awayTeam: fixture.teams.away.name,
      commenceTime: fixture.fixture.date,
      homeOdds: parseFloat(home.odd),
      drawOdds: parseFloat(draw.odd),
      awayOdds: parseFloat(away.odd),
      bookmaker: 'Bet365',
      source: 'api-football'
    };
  }

  /* ── Step 1: Fetch fixtures for all leagues in parallel ── */
  async function fetchFixtures(dateParam, season) {
    var headers = { 'x-apisports-key': APIF_KEY };
    var results = await Promise.all(
      LEAGUES.map(function(leagueId) {
        var url = APIF_BASE + '/fixtures?league=' + leagueId + '&season=' + season + '&' + dateParam;
        return fetch(PROXY + url, { headers: headers })
          .then(function(r) { return r.json(); })
          .catch(function() { return { response: [] }; })
          .then(function(r) {
            console.log('Fixtures response for league', leagueId, JSON.stringify(r).slice(0, 300));
            return r;
          });
      })
    );
    var all = [];
    results.forEach(function(r) {
      (r.response || []).forEach(function(f) { all.push(f); });
    });
    return all;
  }

  /* ── Steps 2+3: Fetch odds for each fixture and normalise ── */
  async function fetchOddsForFixtures(fixtures) {
    var headers = { 'x-apisports-key': APIF_KEY };
    var results = await Promise.all(
      fixtures.slice(0, 20).map(function(f) {
        var leagueId = f.league && f.league.id;
        var leagueName = LEAGUE_NAMES[leagueId] || (f.league && f.league.name) || 'Ukendt liga';
        var fixtureId = f.fixture.id;
        var url = APIF_BASE + '/odds?fixture=' + fixtureId + '&bookmaker=8';
        return fetch(PROXY + url, { headers: headers })
          .then(function(r) { return r.json(); })
          .catch(function() { return { response: [] }; })
          .then(function(od) {
            console.log('Odds response for fixture', fixtureId, JSON.stringify(od).slice(0, 300));
            var match = normalizeApifMatch(f, od.response || [], leagueName);
            return match;
          });
      })
    );
    var matches = results.filter(Boolean);
    console.log('Total matches after normalising:', matches.length);
    console.log('Sample match:', JSON.stringify(matches[0]));
    return matches;
  }

  /* ── Render helpers ── */
  function oddsBtn(matchId, outcomeName, price) {
    var disp = outcomeName === 'Draw' ? 'X' : outcomeName;
    return '<button class="odds-btn"' +
      ' data-mid="' + esc(matchId) + '"' +
      ' data-outcome="' + esc(outcomeName) + '"' +
      ' data-odds="' + price + '">' +
      '<span class="odds-name">' + esc(disp) + '</span>' +
      '<span class="odds-val">' + price + '</span>' +
      '</button>';
  }

  function renderCard(match) {
    matchStore[match.id] = match;
    var h = typeof match.homeOdds === 'number' ? match.homeOdds.toFixed(2) : '–';
    var d = typeof match.drawOdds === 'number' ? match.drawOdds.toFixed(2) : '–';
    var a = typeof match.awayOdds === 'number' ? match.awayOdds.toFixed(2) : '–';
    return '<div class="match-card">' +
      '<div class="match-time">' + esc(fmtDate(match.commenceTime)) + '</div>' +
      '<div class="match-odds-row">' +
        oddsBtn(match.id, match.homeTeam, h) +
        oddsBtn(match.id, 'Draw', d) +
        oddsBtn(match.id, match.awayTeam, a) +
      '</div>' +
      '<div class="match-bookmaker">bet365 · via API-Football</div>' +
    '</div>';
  }

  function renderMatches(matches) {
    var byLeague = {};
    matches.forEach(function(m) {
      var lg = m.leagueName || 'Ukendt liga';
      if (!byLeague[lg]) byLeague[lg] = [];
      byLeague[lg].push(m);
    });
    var html = '';
    Object.keys(byLeague).sort().forEach(function(lg) {
      var cards = byLeague[lg].map(renderCard).filter(Boolean);
      if (!cards.length) return;
      html += '<div class="league-section">' +
        '<h2 class="league-header">' + esc(lg) + '</h2>' +
        '<div class="match-list">' + cards.join('') + '</div>' +
        '</div>';
    });
    return html;
  }

  /* ── Main loader ── */
  async function loadOdds() {
    matchStore = {};
    var container = document.getElementById('matchesContainer');
    container.innerHTML = '<div class="loading-state"><div class="spinner"></div><span>Henter kampe…</span></div>';
    try {
      var allMatches;
      var cachedTime = parseInt(localStorage.getItem(CACHE_TIME_KEY) || '0', 10);
      var cachedData = localStorage.getItem(CACHE_KEY);
      if (cachedData && Date.now() - cachedTime < CACHE_TTL_MS) {
        allMatches = JSON.parse(cachedData);
      } else {
        var today = todayDateStr();

        // Step 1 — today's NS fixtures across all leagues (season 2025)
        var allFixtures = await fetchFixtures('date=' + today, 2025);
        var fixtures = allFixtures.filter(function(f) {
          return f.fixture && f.fixture.status && f.fixture.status.short === 'NS';
        });

        // Season fallback — retry with 2024 if 2025 returned nothing
        if (!fixtures.length) {
          console.log('No fixtures for season 2025, retrying with 2024');
          allFixtures = await fetchFixtures('date=' + today, 2024);
          fixtures = allFixtures.filter(function(f) {
            return f.fixture && f.fixture.status && f.fixture.status.short === 'NS';
          });
        }

        console.log('Total fixtures found:', fixtures.length);
        console.log('Sample fixture:', JSON.stringify(fixtures[0]));

        // Date-range fallback — widen to next 7 days, no NS filter
        if (!fixtures.length) {
          console.log('No NS fixtures today, widening to 7 days');
          fixtures = await fetchFixtures('from=' + today + '&to=' + futureDateStr(7), 2025);
          if (!fixtures.length) {
            fixtures = await fetchFixtures('from=' + today + '&to=' + futureDateStr(7), 2024);
          }
          console.log('Total fixtures found (7-day fallback):', fixtures.length);
        }

        console.log('Rendering matches:', fixtures.length);

        // Steps 2+3 — odds + normalise (capped at 20 fixtures)
        allMatches = await fetchOddsForFixtures(fixtures);

        localStorage.setItem(CACHE_KEY, JSON.stringify(allMatches));
        localStorage.setItem(CACHE_TIME_KEY, String(Date.now()));
      }

      if (!allMatches.length) {
        container.innerHTML = '<div class="empty-state"><p>Ingen kampe tilgængelige</p></div>';
        return;
      }
      var html = renderMatches(allMatches);
      if (!html) {
        container.innerHTML = '<div class="empty-state"><p>Ingen kampe med odds tilgængelige</p></div>';
        return;
      }
      container.innerHTML = html;
    } catch (err) {
      container.innerHTML = '<div class="error-state">' +
        '<p>Kunne ikke hente kampe. Tjek forbindelsen og prøv igen.</p>' +
        '<button class="btn-retry" id="btnRetry">Prøv igen</button>' +
        '</div>';
      document.getElementById('btnRetry').addEventListener('click', loadOdds);
    }
  }

  /* ── Bet slip ── */
  function openSlip(matchId, outcome, odds) {
    var match = matchStore[matchId];
    if (!match) return;
    current = { matchId: matchId, outcome: outcome, odds: parseFloat(odds) };
    document.getElementById('slipMatchName').textContent = match.homeTeam + ' vs ' + match.awayTeam;
    document.getElementById('slipLeague').textContent = match.leagueName || '';
    document.getElementById('slipSelLabel').textContent = selectionLabel(outcome, match.homeTeam, match.awayTeam);
    document.getElementById('slipOddsBadge').textContent = parseFloat(odds).toFixed(2);
    var si = document.getElementById('stakeInput');
    si.value = '';
    document.getElementById('potentialWin').textContent = '0 kr';
    document.getElementById('betSlip').classList.add('open');
    document.getElementById('betSlip').setAttribute('aria-hidden', 'false');
    document.getElementById('slipBackdrop').classList.add('active');
    si.focus();
  }

  function closeSlip() {
    document.getElementById('betSlip').classList.remove('open');
    document.getElementById('betSlip').setAttribute('aria-hidden', 'true');
    document.getElementById('slipBackdrop').classList.remove('active');
    document.querySelectorAll('.odds-btn.selected').forEach(function(b) { b.classList.remove('selected'); });
    current = null;
  }

  function placeBet() {
    if (!current) return;
    var si = document.getElementById('stakeInput');
    var stake = parseFloat(si.value);
    if (isNaN(stake) || stake < 10) { triggerShake(si); return; }
    var balance = parseFloat(localStorage.getItem('nb_balance') || '0');
    if (stake > balance) { triggerShake(si); return; }
    var match = matchStore[current.matchId];
    if (!match) return;
    localStorage.setItem('nb_balance', String(balance - stake));
    window.dispatchEvent(new Event('nb_balance_updated'));
    var bets = JSON.parse(localStorage.getItem('nb_bets') || '[]');
    bets.push({
      id: Date.now().toString(),
      matchId: current.matchId,
      homeTeam: match.homeTeam,
      awayTeam: match.awayTeam,
      league: match.leagueName || '',
      selection: current.outcome,
      odds: current.odds,
      stake: stake,
      potentialWin: stake * current.odds,
      placedAt: new Date().toISOString(),
      commenceTime: match.commenceTime,
      status: 'active'
    });
    localStorage.setItem('nb_bets', JSON.stringify(bets));
    window.dispatchEvent(new Event('nb_bets_updated'));
    closeSlip();
  }

  function triggerShake(el) {
    el.classList.remove('shake');
    void el.offsetWidth;
    el.classList.add('shake');
    el.addEventListener('animationend', function() { el.classList.remove('shake'); }, { once: true });
    el.focus();
  }

  /* ── Event delegation ── */
  document.getElementById('matchesContainer').addEventListener('click', function(e) {
    var btn = e.target.closest('.odds-btn');
    if (!btn) return;
    document.querySelectorAll('.odds-btn.selected').forEach(function(b) { b.classList.remove('selected'); });
    btn.classList.add('selected');
    openSlip(btn.getAttribute('data-mid'), btn.getAttribute('data-outcome'), btn.getAttribute('data-odds'));
  });

  document.getElementById('stakeInput').addEventListener('input', function() {
    var stake = parseFloat(this.value) || 0;
    var odds = current ? current.odds : 0;
    document.getElementById('potentialWin').textContent = stake > 0 && odds > 0 ? fmtKr(stake * odds) : '0 kr';
  });

  document.getElementById('slipClose').addEventListener('click', closeSlip);
  document.getElementById('slipCancel').addEventListener('click', closeSlip);
  document.getElementById('slipBackdrop').addEventListener('click', closeSlip);
  document.getElementById('slipPlace').addEventListener('click', placeBet);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeSlip(); });

  loadOdds();
})();
</script>
