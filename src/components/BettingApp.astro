---
// BettingApp — fetches odds, renders match cards, manages bet slip
---

<section id="bettingApp">
  <!-- Active bets strip -->
  <div id="activeBetsStrip" class="active-bets-strip" style="display:none">
    <div class="strip-label">Aktive indsatser</div>
    <div class="strip-scroll" id="stripScroll"></div>
  </div>

  <!-- Search bar -->
  <div class="search-wrap">
    <div class="search-inner">
      <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input type="text" id="searchInput" class="search-input" placeholder="Søg efter hold eller liga..." autocomplete="off" spellcheck="false" />
      <button class="search-clear" id="searchClear" style="display:none" aria-label="Ryd søgning">×</button>
    </div>
  </div>

  <div id="matchesContainer">
    <div class="loading-state">
      <div class="spinner"></div>
      <span>Henter kampe…</span>
    </div>
  </div>
  <p id="apiQuota" class="api-quota"></p>
</section>

<!-- Bet slip backdrop -->
<div class="slip-backdrop" id="slipBackdrop"></div>

<!-- Bet slip panel -->
<aside class="bet-slip" id="betSlip" aria-hidden="true" aria-label="Bet slip">
  <div class="slip-head">
    <span class="slip-title">Bet Slip</span>
    <button class="slip-close" id="slipClose" aria-label="Luk">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="slip-body">
    <div class="slip-match-name" id="slipMatchName"></div>
    <div class="slip-league" id="slipLeague"></div>
    <div class="slip-selection-row">
      <span class="slip-sel-label" id="slipSelLabel"></span>
      <span class="slip-odds-badge" id="slipOddsBadge"></span>
    </div>

    <div class="stake-field">
      <label for="stakeInput" class="stake-label">Indsats</label>
      <div class="stake-wrap">
        <input
          type="number"
          id="stakeInput"
          class="stake-input"
          placeholder="0"
          min="10"
          step="10"
        />
        <span class="stake-kr">kr</span>
      </div>
    </div>

    <div class="potential-row">
      <span class="potential-label">Mulig gevinst</span>
      <span class="potential-val" id="potentialWin">0 kr</span>
    </div>
  </div>

  <div class="slip-foot">
    <button class="btn-cancel" id="slipCancel">Annuller</button>
    <button class="btn-place" id="slipPlace">Placer indsats</button>
  </div>
</aside>

<style is:global>
  /* ── Loading / error / empty ── */
  .loading-state,
  .error-state,
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 5rem 2rem;
    color: var(--muted);
    text-align: center;
    font-size: 0.95rem;
  }
  .spinner {
    width: 30px; height: 30px;
    border: 3px solid rgba(255,255,255,0.08);
    border-top-color: var(--green);
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .btn-retry {
    background: var(--green); color: #fff; border: none;
    border-radius: 8px; padding: 0.55rem 1.2rem;
    font-size: 0.88rem; font-weight: 600; cursor: pointer;
    font-family: var(--font); transition: background 0.15s ease;
  }
  .btn-retry:hover { background: #00784f; }
  .api-quota { margin-top: 1.5rem; font-size: 0.7rem; color: rgba(255,255,255,0.15); text-align: right; }

  /* ── Active bets strip ── */
  .active-bets-strip { margin-bottom: 1.25rem; }
  .strip-label {
    font-size: 0.63rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--mint); margin-bottom: 0.55rem;
  }
  .strip-scroll {
    display: flex; gap: 0.6rem; overflow-x: auto;
    padding-bottom: 0.4rem; scrollbar-width: none;
  }
  .strip-scroll::-webkit-scrollbar { display: none; }
  .strip-card {
    flex-shrink: 0; width: 200px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    border-radius: 10px; padding: 0.7rem 0.85rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .strip-match {
    font-size: 0.79rem; font-weight: 600; color: var(--text);
    margin-bottom: 0.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .strip-sel {
    font-size: 0.77rem; color: var(--gold); font-weight: 600;
    margin-bottom: 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .strip-details { font-size: 0.74rem; color: var(--muted); margin-bottom: 0.12rem; }
  .strip-win { color: var(--mint); font-weight: 600; }
  .strip-league {
    font-size: 0.63rem; color: var(--muted);
    text-transform: uppercase; letter-spacing: 0.06em;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* ── Search bar ── */
  .search-wrap {
    position: sticky; top: 72px; z-index: 50;
    background: var(--dark);
    padding: 0.65rem 0 0.75rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .search-inner { position: relative; display: flex; align-items: center; }
  .search-icon {
    position: absolute; left: 0.85rem;
    color: var(--muted); pointer-events: none; flex-shrink: 0;
  }
  .search-input {
    width: 100%; background: var(--surface2);
    border: 1px solid var(--border); border-radius: 10px;
    padding: 0.68rem 2.4rem 0.68rem 2.5rem;
    color: var(--text); font-size: 0.9rem; font-family: var(--font);
    outline: none; transition: border-color 0.15s ease;
  }
  .search-input::placeholder { color: var(--muted); }
  .search-input:focus { border-color: var(--mint); }
  .search-clear {
    position: absolute; right: 0.7rem;
    background: none; border: none; color: var(--muted);
    cursor: pointer; font-size: 1.15rem; line-height: 1;
    padding: 0.2rem 0.3rem; border-radius: 4px;
    transition: color 0.15s ease;
  }
  .search-clear:hover { color: var(--text); }
  .search-no-results {
    padding: 3rem 2rem; text-align: center;
    color: var(--muted); font-size: 0.9rem;
  }

  /* ── Match container ── */
  #matchesContainer { display: flex; flex-direction: column; gap: 0.5rem; }

  /* ── League sections ── */
  .league-header {
    width: 100%; display: flex; align-items: center; gap: 0.55rem;
    background: none; border: none; border-bottom: 1px solid var(--border);
    padding: 0.6rem 0; cursor: pointer; font-family: var(--font);
    transition: opacity 0.15s ease;
  }
  .league-header:hover { opacity: 0.75; }
  .league-name {
    font-size: 0.67rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--mint); flex: 1; text-align: left;
  }
  .league-count {
    font-size: 0.67rem; font-weight: 700; color: var(--muted);
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 999px; padding: 0.08rem 0.48rem;
    min-width: 1.5em; text-align: center;
  }
  .league-chevron {
    color: var(--muted); transition: transform 0.2s ease; flex-shrink: 0;
  }
  .league-section.expanded .league-chevron { transform: rotate(180deg); }
  .league-body { display: none; padding-top: 0.45rem; }
  .league-section.expanded .league-body { display: block; }
  .match-list { display: flex; flex-direction: column; gap: 0.4rem; padding-bottom: 0.65rem; }

  /* ── Match card ── */
  .match-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 1rem 1.1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .match-card:hover {
    border-color: #4a5272;
    transform: translateY(-1px);
    box-shadow: 0 5px 18px rgba(0,0,0,0.4);
  }
  .match-teams {
    display: flex; align-items: center; gap: 0.45rem; margin-bottom: 0.3rem;
  }
  .team-name {
    font-size: 0.88rem; font-weight: 600; color: var(--text);
    flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .team-name.away { text-align: right; }
  .vs-sep { font-size: 0.7rem; color: var(--muted); font-weight: 500; flex-shrink: 0; }
  .match-time { font-size: 0.71rem; color: var(--muted); margin-bottom: 0.7rem; text-transform: capitalize; }
  .match-odds-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.4rem; }
  .match-bookmaker { font-size: 0.63rem; color: rgba(255,255,255,0.2); text-align: right; margin-top: 0.4rem; }

  /* ── Odds buttons ── */
  .odds-btn {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 0.5rem 0.35rem; cursor: pointer;
    display: flex; flex-direction: column; align-items: center; gap: 0.15rem;
    min-width: 0; transition: background 0.15s ease, border-color 0.15s ease;
  }
  .odds-btn:hover { background: var(--green); border-color: var(--green); }
  .odds-btn:hover .odds-label,
  .odds-btn:hover .odds-val { color: #fff; }
  .odds-btn.selected { background: var(--gold); border-color: var(--gold); }
  .odds-btn.selected .odds-label,
  .odds-btn.selected .odds-val { color: var(--dark); font-weight: 700; }
  .odds-label {
    font-size: 0.67rem; color: var(--muted); white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; max-width: 100%;
    text-align: center; line-height: 1.2; transition: color 0.15s ease;
  }
  .odds-val {
    font-size: 0.94rem; font-weight: 700; color: var(--text);
    line-height: 1; transition: color 0.15s ease;
  }

  /* ── Bet slip ── */
  .slip-backdrop {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.6); z-index: 200; animation: fadeIn 0.2s ease;
  }
  .slip-backdrop.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .bet-slip {
    position: fixed; top: 0; right: 0; bottom: 0; width: 340px;
    background: var(--surface); border-left: 1px solid var(--border);
    z-index: 201; display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .bet-slip.open { transform: translateX(0); }
  .slip-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.1rem 1.4rem; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .slip-title { font-size: 0.95rem; font-weight: 700; letter-spacing: 0.02em; }
  .slip-close {
    background: none; border: none; color: var(--muted); cursor: pointer;
    padding: 0.25rem; border-radius: 4px; display: flex; align-items: center;
    transition: color 0.15s ease;
  }
  .slip-close:hover { color: var(--text); }
  .slip-body {
    flex: 1; padding: 1.4rem; overflow-y: auto;
    display: flex; flex-direction: column; gap: 1.1rem;
  }
  .slip-match-name { font-size: 0.95rem; font-weight: 700; line-height: 1.35; color: var(--text); }
  .slip-league {
    font-size: 0.72rem; color: var(--mint); font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; margin-top: -0.6rem;
  }
  .slip-selection-row {
    display: flex; align-items: center; justify-content: space-between;
    background: var(--surface2); border-radius: 8px; padding: 0.7rem 0.9rem;
  }
  .slip-sel-label { font-size: 0.85rem; color: var(--muted); }
  .slip-odds-badge { font-size: 1.4rem; font-weight: 800; color: var(--gold); letter-spacing: -0.02em; }
  .stake-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .stake-label { font-size: 0.78rem; color: var(--muted); font-weight: 500; }
  .stake-wrap { position: relative; }
  .stake-input {
    width: 100%; background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 0.75rem 2.8rem 0.75rem 0.9rem;
    color: var(--text); font-size: 1.1rem; font-weight: 600; outline: none;
    transition: border-color 0.15s ease; font-family: var(--font); -moz-appearance: textfield;
  }
  .stake-input::-webkit-inner-spin-button,
  .stake-input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .stake-input:focus { border-color: var(--green); }
  .stake-input.shake { animation: shake 0.38s ease; border-color: #e05555 !important; }
  @keyframes shake {
    0%,100% { transform: translateX(0); }
    20%,60%  { transform: translateX(-5px); }
    40%,80%  { transform: translateX(5px); }
  }
  .stake-kr {
    position: absolute; right: 0.85rem; top: 50%; transform: translateY(-50%);
    font-size: 0.82rem; color: var(--muted); pointer-events: none;
  }
  .potential-row {
    display: flex; justify-content: space-between; align-items: center;
    background: var(--surface2); border-radius: 8px; padding: 0.7rem 0.9rem;
  }
  .potential-label { font-size: 0.82rem; color: var(--muted); }
  .potential-val { font-size: 1rem; font-weight: 700; color: var(--mint); }
  .slip-foot {
    display: flex; gap: 0.65rem; padding: 1.1rem 1.4rem;
    border-top: 1px solid var(--border); flex-shrink: 0;
  }
  .btn-cancel {
    flex: 1; background: none; border: 1px solid var(--border); color: var(--muted);
    border-radius: 8px; padding: 0.72rem; cursor: pointer; font-size: 0.9rem;
    font-family: var(--font); transition: border-color 0.15s ease, color 0.15s ease;
  }
  .btn-cancel:hover { border-color: rgba(255,255,255,0.2); color: var(--text); }
  .btn-place {
    flex: 2; background: var(--green); color: #fff; border: none;
    border-radius: 8px; padding: 0.72rem; cursor: pointer;
    font-size: 0.9rem; font-weight: 600; font-family: var(--font);
    transition: background 0.15s ease;
  }
  .btn-place:hover { background: #00784f; }

  /* ── Mobile ── */
  @media (max-width: 620px) {
    .bet-slip {
      top: auto; left: 0; right: 0; width: 100%; height: 88vh;
      border-left: none; border-top: 1px solid var(--border);
      border-radius: 16px 16px 0 0; transform: translateY(100%);
    }
    .bet-slip.open { transform: translateY(0); }
    .match-odds-row { gap: 0.3rem; }
  }
</style>

<script is:inline>
(function () {
  var LEAGUES = [
    'soccer_epl',
    'soccer_england_league1',
    'soccer_germany_bundesliga',
    'soccer_germany_bundesliga2',
    'soccer_italy_serie_a',
    'soccer_italy_serie_b',
    'soccer_france_ligue_one',
    'soccer_france_ligue_two',
    'soccer_denmark_superliga',
    'soccer_netherlands_eredivisie',
    'soccer_portugal_primeira_liga',
    'soccer_turkey_super_league',
    'soccer_norway_eliteserien',
    'soccer_sweden_allsvenskan',
    'soccer_scotland_premiership'
  ];

  var ODDS_API_KEYS   = [
    '3a9a2207c105619994c376d25f8b34ed',
    'c2be06815c1270ef08b60c8b7d72111d'
  ];
  var ODDS_API_IO_KEY = 'c9261af1065824f587395be2eb5865f2d73eeb66aa56bbde05b859a31f64990a';
  var CACHE_KEY      = 'nb_odds_cache';
  var CACHE_TIME_KEY = 'nb_odds_cache_time';
  var CACHE_TTL_MS   = 30 * 60 * 1000;

  var matchStore = {};
  var current = null;
  var allMatchesData = [];

  /* ── Utilities ── */
  function fmtKr(n) {
    return new Intl.NumberFormat('da-DK').format(Math.round(n)) + ' kr';
  }
  function fmtDate(iso) {
    return new Intl.DateTimeFormat('da-DK', {
      timeZone: 'Europe/Copenhagen',
      weekday: 'short', day: 'numeric', month: 'short',
      hour: '2-digit', minute: '2-digit'
    }).format(new Date(iso));
  }
  function esc(s) {
    return String(s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
  function selectionLabel(outcome, homeTeam, awayTeam) {
    if (outcome === 'Draw') return 'Uafgjort';
    if (outcome === homeTeam) return homeTeam + ' vinder';
    return awayTeam + ' vinder';
  }

  /* ── Fetch from The Odds API — tries each key in order, falls back on 401/429 ── */
  async function fetchAllOdds() {
    var matches = [];
    for (var i = 0; i < LEAGUES.length; i++) {
      if (i > 0) await new Promise(function(r) { setTimeout(r, 150); });
      var result = [];
      for (var k = 0; k < ODDS_API_KEYS.length; k++) {
        var res = await fetch(
          'https://api.the-odds-api.com/v4/sports/' + LEAGUES[i] +
          '/odds/?apiKey=' + ODDS_API_KEYS[k] +
          '&regions=eu&markets=h2h&oddsFormat=decimal&bookmakers=bet365'
        ).catch(function() { return { ok: false, status: 0 }; });
        if (res.ok) { result = await res.json(); break; }
        if (res.status !== 401 && res.status !== 429) break; // unexpected error, don't retry
        console.log('Key', k, 'failed (' + res.status + ') for', LEAGUES[i] + ', trying next key');
      }
      if (Array.isArray(result)) matches = matches.concat(result);
    }
    console.log('Total matches loaded:', matches.length);
    return matches;
  }

  /* ── Fetch from odds-api.io — prefers Bet365, falls back to first available ── */
  async function fetchOddsApiIo() {
    // Bookmakers and events in parallel
    var parallel = await Promise.all([
      fetch('https://api.odds-api.io/v3/bookmakers?apiKey=' + ODDS_API_IO_KEY)
        .then(function(r) { return r.ok ? r.json() : null; }).catch(function() { return null; }),
      fetch('https://api.odds-api.io/v3/events?apiKey=' + ODDS_API_IO_KEY + '&sport=football&status=pending&limit=100')
        .then(function(r) { return r.ok ? r.json() : null; }).catch(function() { return null; })
    ]);

    var bmRaw  = parallel[0];
    var evRaw  = parallel[1];

    var bmList = Array.isArray(bmRaw) ? bmRaw : (bmRaw && Array.isArray(bmRaw.data) ? bmRaw.data : []);
    var events = Array.isArray(evRaw) ? evRaw : (evRaw && Array.isArray(evRaw.data) ? evRaw.data : []);

    console.log('odds-api.io bookmakers:', bmList.map(function(b) { return b.name || b.key || b.slug; }));
    console.log('odds-api.io events fetched:', events.length);

    if (!bmList.length || !events.length) return [];

    // Pick Bet365 by name, or fall back to first bookmaker
    var bet365 = bmList.find(function(b) {
      return (b.name || b.key || b.slug || '').toLowerCase().indexOf('bet365') !== -1;
    });
    if (!bet365) {
      console.log('odds-api.io: Bet365 not available in bookmaker list');
      return [];
    }
    var chosenBm = bet365.name || bet365.key || bet365.slug;

    console.log('odds-api.io using bookmaker:', chosenBm);

    // Batch odds in groups of 10
    var chunks = [];
    for (var i = 0; i < events.length; i += 10) chunks.push(events.slice(i, i + 10));

    var oddsResults = await Promise.all(
      chunks.map(function(chunk) {
        var ids = chunk.map(function(e) { return e.id; }).join(',');
        return fetch(
          'https://api.odds-api.io/v3/odds/multi?apiKey=' + ODDS_API_IO_KEY +
          '&eventIds=' + ids + '&bookmakers=' + encodeURIComponent(chosenBm)
        ).then(function(r) {
          if (!r.ok) { console.log('odds/multi error:', r.status); return []; }
          return r.json();
        }).catch(function() { return []; });
      })
    );

    var oddsArr = [];
    oddsResults.forEach(function(r) {
      if (Array.isArray(r)) r.forEach(function(x) { oddsArr.push(x); });
      else if (r && Array.isArray(r.data)) r.data.forEach(function(x) { oddsArr.push(x); });
    });

    if (oddsArr.length) {
      console.log('odds-api.io raw odds sample:', JSON.stringify(oddsArr[0]).slice(0, 500));
    }

    var oddsMap = {};
    oddsArr.forEach(function(item) {
      if (item && item.id != null) oddsMap[String(item.id)] = item;
    });

    var matches = [];
    events.forEach(function(event) {
      var odds = oddsMap[String(event.id)];
      if (!odds || !odds.bookmakers) return;
      var bmData = odds.bookmakers[chosenBm] || odds.bookmakers[Object.keys(odds.bookmakers)[0]];
      var actualBm = odds.bookmakers[chosenBm] ? chosenBm : Object.keys(odds.bookmakers)[0];
      if (!bmData) return;
      var ml = bmData.find ? bmData.find(function(m) { return m.name === 'ML'; }) : null;
      if (!ml || !ml.odds || !ml.odds[0]) return;
      var o = ml.odds[0];
      if (!o.home || !o.away) return;
      matches.push({
        id: 'oapio_' + event.id,
        leagueName: event.league ? event.league.name : 'Football',
        homeTeam: event.home,
        awayTeam: event.away,
        commenceTime: event.date,
        homeOdds: parseFloat(o.home),
        drawOdds: o.draw ? parseFloat(o.draw) : null,
        awayOdds: parseFloat(o.away),
        bookmaker: actualBm
      });
    });
    console.log('odds-api.io matches found:', matches.length);
    return matches;
  }

  /* ── Normalise a raw Odds API match object ── */
  function normalizeMatch(match) {
    var bookmakers = match.bookmakers || [];
    var bm = bookmakers.find(function(b) { return b.key === 'bet365'; });
    if (!bm) return null;
    var market = (bm.markets || []).find(function(m) { return m.key === 'h2h'; });
    if (!market) return null;
    var outcomes = market.outcomes || [];
    var homeOutcome = outcomes.find(function(o) { return o.name === match.home_team; });
    var awayOutcome = outcomes.find(function(o) { return o.name === match.away_team; });
    var drawOutcome = outcomes.find(function(o) { return o.name === 'Draw'; });
    if (!homeOutcome || !awayOutcome) return null;
    return {
      id: match.id,
      leagueName: match.sport_title,
      homeTeam: match.home_team,
      awayTeam: match.away_team,
      commenceTime: match.commence_time,
      homeOdds: homeOutcome.price,
      drawOdds: drawOutcome ? drawOutcome.price : null,
      awayOdds: awayOutcome.price,
      bookmaker: bm.title || bm.key
    };
  }

  /* ── Render helpers ── */
  function oddsBtn(matchId, outcomeName, price, label) {
    return '<button class="odds-btn"' +
      ' data-mid="' + esc(matchId) + '"' +
      ' data-outcome="' + esc(outcomeName) + '"' +
      ' data-odds="' + price + '">' +
      '<span class="odds-label">' + esc(label) + '</span>' +
      '<span class="odds-val">' + price + '</span>' +
      '</button>';
  }

  function renderCard(match) {
    matchStore[match.id] = match;
    var h = typeof match.homeOdds === 'number' ? match.homeOdds.toFixed(2) : '–';
    var d = typeof match.drawOdds === 'number' ? match.drawOdds.toFixed(2) : '–';
    var a = typeof match.awayOdds === 'number' ? match.awayOdds.toFixed(2) : '–';
    return '<div class="match-card">' +
      '<div class="match-teams">' +
        '<span class="team-name home">' + esc(match.homeTeam) + '</span>' +
        '<span class="vs-sep">vs</span>' +
        '<span class="team-name away">' + esc(match.awayTeam) + '</span>' +
      '</div>' +
      '<div class="match-time">' + esc(fmtDate(match.commenceTime)) + '</div>' +
      '<div class="match-odds-row">' +
        oddsBtn(match.id, match.homeTeam, h, '1') +
        oddsBtn(match.id, 'Draw', d, 'Uafgjort') +
        oddsBtn(match.id, match.awayTeam, a, '2') +
      '</div>' +
      '<div class="match-bookmaker">' + esc(match.bookmaker) + '</div>' +
    '</div>';
  }

  function renderMatches(matches, searching) {
    console.log('Render called with:', matches.length, 'matches');
    var byLeague = {};
    matches.forEach(function(m) {
      var lg = m.leagueName || 'Ukendt liga';
      if (!byLeague[lg]) byLeague[lg] = [];
      byLeague[lg].push(m);
    });
    var leagues = Object.keys(byLeague).sort();
    var html = '';
    leagues.forEach(function(lg, idx) {
      var sorted = byLeague[lg].slice().sort(function(a, b) {
        return new Date(a.commenceTime) - new Date(b.commenceTime);
      });
      var cards = sorted.map(renderCard).filter(Boolean);
      if (!cards.length) return;
      var expanded = searching || idx < 3;
      html += '<div class="league-section' + (expanded ? ' expanded' : '') + '">' +
        '<button class="league-header" aria-expanded="' + expanded + '">' +
          '<span class="league-name">' + esc(lg) + '</span>' +
          '<span class="league-count">' + cards.length + '</span>' +
          '<svg class="league-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>' +
        '</button>' +
        '<div class="league-body"><div class="match-list">' + cards.join('') + '</div></div>' +
      '</div>';
    });
    return html;
  }

  function displayMatches(matches, searching) {
    var container = document.getElementById('matchesContainer');
    if (!matches.length) {
      container.innerHTML = '<div class="empty-state"><p>Ingen kampe tilgængelige i øjeblikket. Prøv igen senere.</p></div>';
      return;
    }
    var html = renderMatches(matches, searching);
    container.innerHTML = html || '<div class="empty-state"><p>Ingen kampe tilgængelige i øjeblikket. Prøv igen senere.</p></div>';
  }

  function renderActiveBetsStrip() {
    var bets = JSON.parse(localStorage.getItem('nb_bets') || '[]');
    var active = bets.filter(function(b) { return b.status === 'active'; });
    var strip = document.getElementById('activeBetsStrip');
    var scroll = document.getElementById('stripScroll');
    if (!active.length) { strip.style.display = 'none'; return; }
    strip.style.display = '';
    scroll.innerHTML = active.map(function(b) {
      var sel = b.selection === 'Draw' ? 'Uafgjort'
        : b.selection === b.homeTeam ? b.homeTeam + ' vinder'
        : b.awayTeam + ' vinder';
      return '<div class="strip-card">' +
        '<div class="strip-match">' + esc(b.homeTeam) + ' vs ' + esc(b.awayTeam) + '</div>' +
        '<div class="strip-sel">' + esc(sel) + '</div>' +
        '<div class="strip-details">' + fmtKr(b.stake) + ' → <span class="strip-win">' + fmtKr(b.potentialWin) + '</span></div>' +
        '<div class="strip-league">' + esc(b.league || '') + '</div>' +
      '</div>';
    }).join('');
  }

  /* ── Main loader ── */
  async function loadOdds() {
    matchStore = {};
    var container = document.getElementById('matchesContainer');
    container.innerHTML = '<div class="loading-state"><div class="spinner"></div><span>Henter kampe…</span></div>';

    var cachedTime = parseInt(localStorage.getItem(CACHE_TIME_KEY) || '0', 10);
    var cachedData = localStorage.getItem(CACHE_KEY);

    if (cachedData && Date.now() - cachedTime < CACHE_TTL_MS) {
      try {
        var cached = JSON.parse(cachedData);
        if (cached.length > 0) {
          console.log('Serving from cache:', cached.length, 'matches');
          allMatchesData = cached;
          renderActiveBetsStrip();
          displayMatches(cached, false);
          return;
        }
      } catch (e) {}
      // cached empty or invalid — fall through to fresh fetch
    }

    try {
      var fetched = await Promise.all([fetchOddsApiIo(), fetchAllOdds()]);
      var bet365Matches = fetched[0];
      var oddsApiMatches = fetched[1].map(normalizeMatch).filter(Boolean);

      var seen = {};
      bet365Matches.forEach(function(m) { seen[m.homeTeam + '|' + m.awayTeam] = true; });
      var extras = oddsApiMatches.filter(function(m) { return !seen[m.homeTeam + '|' + m.awayTeam]; });

      var allMatches = bet365Matches.concat(extras);
      console.log('Normalised matches:', allMatches.length, JSON.stringify(allMatches[0]));

      if (allMatches.length) {
        localStorage.setItem(CACHE_KEY, JSON.stringify(allMatches));
        localStorage.setItem(CACHE_TIME_KEY, String(Date.now()));
      }

      allMatchesData = allMatches;
      renderActiveBetsStrip();
      displayMatches(allMatches, false);
    } catch (err) {
      // If fresh fetch fails, try stale cache rather than showing nothing
      if (cachedData) {
        var stale = JSON.parse(cachedData);
        allMatchesData = stale;
        renderActiveBetsStrip();
        displayMatches(stale, false);
        return;
      }
      container.innerHTML = '<div class="error-state">' +
        '<p>Kunne ikke hente kampe. Tjek forbindelsen og prøv igen.</p>' +
        '<button class="btn-retry" id="btnRetry">Prøv igen</button>' +
        '</div>';
      document.getElementById('btnRetry').addEventListener('click', loadOdds);
    }
  }

  /* ── Bet slip ── */
  function openSlip(matchId, outcome, odds) {
    var match = matchStore[matchId];
    if (!match) return;
    current = { matchId: matchId, outcome: outcome, odds: parseFloat(odds) };
    document.getElementById('slipMatchName').textContent = match.homeTeam + ' vs ' + match.awayTeam;
    document.getElementById('slipLeague').textContent = match.leagueName || '';
    document.getElementById('slipSelLabel').textContent = selectionLabel(outcome, match.homeTeam, match.awayTeam);
    document.getElementById('slipOddsBadge').textContent = parseFloat(odds).toFixed(2);
    var si = document.getElementById('stakeInput');
    si.value = '';
    document.getElementById('potentialWin').textContent = '0 kr';
    document.getElementById('betSlip').classList.add('open');
    document.getElementById('betSlip').setAttribute('aria-hidden', 'false');
    document.getElementById('slipBackdrop').classList.add('active');
    si.focus();
  }

  function closeSlip() {
    document.getElementById('betSlip').classList.remove('open');
    document.getElementById('betSlip').setAttribute('aria-hidden', 'true');
    document.getElementById('slipBackdrop').classList.remove('active');
    document.querySelectorAll('.odds-btn.selected').forEach(function(b) { b.classList.remove('selected'); });
    current = null;
  }

  function placeBet() {
    if (!current) return;
    var si = document.getElementById('stakeInput');
    var stake = parseFloat(si.value);
    if (isNaN(stake) || stake < 10) { triggerShake(si); return; }
    var balance = parseFloat(localStorage.getItem('nb_balance') || '0');
    if (stake > balance) { triggerShake(si); return; }
    var match = matchStore[current.matchId];
    if (!match) return;
    localStorage.setItem('nb_balance', String(balance - stake));
    window.dispatchEvent(new Event('nb_balance_updated'));
    var bets = JSON.parse(localStorage.getItem('nb_bets') || '[]');
    bets.push({
      id: Date.now().toString(),
      matchId: current.matchId,
      homeTeam: match.homeTeam,
      awayTeam: match.awayTeam,
      league: match.leagueName || '',
      selection: current.outcome,
      odds: current.odds,
      stake: stake,
      potentialWin: stake * current.odds,
      placedAt: new Date().toISOString(),
      commenceTime: match.commenceTime,
      status: 'active'
    });
    localStorage.setItem('nb_bets', JSON.stringify(bets));
    window.dispatchEvent(new Event('nb_bets_updated'));
    closeSlip();
  }

  function triggerShake(el) {
    el.classList.remove('shake');
    void el.offsetWidth;
    el.classList.add('shake');
    el.addEventListener('animationend', function() { el.classList.remove('shake'); }, { once: true });
    el.focus();
  }

  /* ── Event delegation ── */
  document.getElementById('matchesContainer').addEventListener('click', function(e) {
    var btn = e.target.closest('.odds-btn');
    if (!btn) return;
    document.querySelectorAll('.odds-btn.selected').forEach(function(b) { b.classList.remove('selected'); });
    btn.classList.add('selected');
    openSlip(btn.getAttribute('data-mid'), btn.getAttribute('data-outcome'), btn.getAttribute('data-odds'));
  });

  document.getElementById('stakeInput').addEventListener('input', function() {
    var stake = parseFloat(this.value) || 0;
    var odds = current ? current.odds : 0;
    document.getElementById('potentialWin').textContent = stake > 0 && odds > 0 ? fmtKr(stake * odds) : '0 kr';
  });

  document.getElementById('slipClose').addEventListener('click', closeSlip);
  document.getElementById('slipCancel').addEventListener('click', closeSlip);
  document.getElementById('slipBackdrop').addEventListener('click', closeSlip);
  document.getElementById('slipPlace').addEventListener('click', placeBet);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeSlip(); });

  /* ── Search ── */
  var searchInput = document.getElementById('searchInput');
  var searchClear = document.getElementById('searchClear');

  searchInput.addEventListener('input', function() {
    var q = this.value.trim();
    searchClear.style.display = q ? '' : 'none';
    if (!q) { displayMatches(allMatchesData, false); return; }
    var lower = q.toLowerCase();
    var filtered = allMatchesData.filter(function(m) {
      return m.homeTeam.toLowerCase().indexOf(lower) !== -1 ||
             m.awayTeam.toLowerCase().indexOf(lower) !== -1 ||
             (m.leagueName || '').toLowerCase().indexOf(lower) !== -1;
    });
    if (!filtered.length) {
      document.getElementById('matchesContainer').innerHTML =
        '<div class="search-no-results">Ingen resultater for \'' + esc(q) + '\'</div>';
      return;
    }
    displayMatches(filtered, true);
  });

  searchClear.addEventListener('click', function() {
    searchInput.value = '';
    searchClear.style.display = 'none';
    displayMatches(allMatchesData, false);
    searchInput.focus();
  });

  /* ── League collapse/expand ── */
  document.getElementById('matchesContainer').addEventListener('click', function(e) {
    var hdr = e.target.closest('.league-header');
    if (!hdr) return;
    var section = hdr.closest('.league-section');
    if (!section) return;
    var expanded = section.classList.toggle('expanded');
    hdr.setAttribute('aria-expanded', expanded ? 'true' : 'false');
  });

  /* ── Refresh strip when bets change ── */
  window.addEventListener('nb_bets_updated', renderActiveBetsStrip);

  loadOdds();
})();
</script>
