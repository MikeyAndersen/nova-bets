---
interface Props {
  title?: string;
  showNav?: boolean;
  requireAuth?: boolean;
  fullHeight?: boolean;
}
const { title = 'NovaBets', showNav = true, requireAuth = false, fullHeight = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — NovaBets</title>
    {requireAuth && (
      <script is:inline>
        if (!localStorage.getItem('nb_auth')) {
          window.location.replace('/login');
        }
      </script>
    )}
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green:      #006442;
        --mint:       #8FE1B0;
        --gold:       #F2C744;
        --dark:       #1a1f2e;
        --surface:    #242938;
        --surface2:   #2e3447;
        --border:     #3a4058;
        --text:       #e8eaf0;
        --muted:      #8b92a8;
        --text-muted: #8b92a8;
        --font:       -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--dark);
        color: var(--text);
        font-family: var(--font);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Grain texture */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.04;
        background-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='300' height='300'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/></filter><rect width='300' height='300' filter='url(%23n)'/></svg>");
        background-repeat: repeat;
        background-size: 300px 300px;
      }

      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0 1.5rem;
        height: 58px;
        background: rgba(26,31,46,0.96);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--border);
      }

      .wordmark {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--gold);
        text-decoration: none;
        letter-spacing: -0.02em;
        flex-shrink: 0;
      }

      .nav-spacer { flex: 1; }

      .balance-pill {
        color: var(--mint);
        font-weight: 600;
        font-size: 0.9rem;
        background: rgba(143,225,176,0.08);
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        border: 1px solid rgba(143,225,176,0.18);
        white-space: nowrap;
      }

      .btn-more {
        background: var(--green);
        color: #fff;
        border: none;
        padding: 0.38rem 0.8rem;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.18s;
        white-space: nowrap;
        font-family: var(--font);
      }
      .btn-more:hover { background: #00784f; }

      .btn-logout {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        padding: 0.35rem;
        border-radius: 6px;
        display: flex;
        align-items: center;
        transition: color 0.18s;
        flex-shrink: 0;
      }
      .btn-logout:hover { color: var(--text); }

      /* Main content */
      .main-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 1.75rem 1.5rem 5rem;
      }

      @media (max-width: 600px) {
        .nav { padding: 0 1rem; gap: 0.5rem; }
        .btn-more { font-size: 0.72rem; padding: 0.32rem 0.6rem; }
        .main-wrap { padding: 1.25rem 1rem 5rem; }
      }
    </style>
  </head>
  <body>
    {showNav && (
      <nav class="nav">
        <a href="/" class="wordmark">NovaBets</a>
        <div class="nav-spacer"></div>
        <span class="balance-pill" id="navBalance">–</span>
        <button class="btn-more" id="btnMore">Få 10.000 kr mere</button>
        <button class="btn-logout" id="btnLogout" title="Log ud" aria-label="Log ud">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </button>
      </nav>
    )}
    {fullHeight ? <slot /> : <div class="main-wrap"><slot /></div>}

    <script is:inline>
      (function () {
        function fmtKr(n) {
          return new Intl.NumberFormat('da-DK').format(Math.round(n)) + ' kr';
        }
        function refreshBalance() {
          var raw = localStorage.getItem('nb_balance');
          if (raw === null) { raw = '10000'; localStorage.setItem('nb_balance', raw); }
          var el = document.getElementById('navBalance');
          if (el) el.textContent = fmtKr(parseFloat(raw));
        }
        refreshBalance();
        window.addEventListener('nb_balance_updated', refreshBalance);

        var btnMore = document.getElementById('btnMore');
        if (btnMore) {
          btnMore.addEventListener('click', function () {
            var bal = parseFloat(localStorage.getItem('nb_balance') || '0');
            localStorage.setItem('nb_balance', String(bal + 10000));
            window.dispatchEvent(new Event('nb_balance_updated'));
          });
        }

        var btnLogout = document.getElementById('btnLogout');
        if (btnLogout) {
          btnLogout.addEventListener('click', function () {
            localStorage.removeItem('nb_auth');
            window.location.href = '/login';
          });
        }
      })();
    </script>
  </body>
</html>
