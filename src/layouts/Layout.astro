---
interface Props {
  title?: string;
  showNav?: boolean;
  requireAuth?: boolean;
  fullHeight?: boolean;
}
const { title = 'NovaBets', showNav = true, requireAuth = false, fullHeight = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — NovaBets</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('nb_theme') || 'standard';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    {requireAuth && (
      <script is:inline>
        if (!localStorage.getItem('nb_auth')) {
          window.location.replace('/login');
        }
      </script>
    )}
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* ── Standard (default) ── */
      :root {
        --green:       #006442;
        --green-hover: #00784f;
        --mint:        #8FE1B0;
        --mint-bg:     rgba(143,225,176,0.08);
        --mint-border: rgba(143,225,176,0.18);
        --gold:        #F2C744;
        --dark:        #1a1f2e;
        --surface:     #242938;
        --surface2:    #2e3447;
        --border:      #3a4058;
        --text:        #e8eaf0;
        --muted:       #8b92a8;
        --text-muted:  #8b92a8;
        --nav-bg:      rgba(26,31,46,0.96);
        --font:        -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      }

      /* ── Torben-tilstand 🇩🇰 ── */
      [data-theme="torben"] {
        --green:       #C60C30;
        --green-hover: #A00828;
        --mint:        #FF8FA0;
        --mint-bg:     rgba(255,143,160,0.08);
        --mint-border: rgba(255,143,160,0.2);
        --gold:        #FFFFFF;
        --dark:        #0D0508;
        --surface:     #1A0B10;
        --surface2:    #26121A;
        --border:      #4A2030;
        --text:        #F0E0E4;
        --muted:       #9A7078;
        --text-muted:  #9A7078;
        --nav-bg:      rgba(13,5,8,0.96);
      }

      /* ── Nova-tilstand 🐕 ── */
      [data-theme="nova"] {
        --green:       #E07B10;
        --green-hover: #C06808;
        --mint:        #FFBC52;
        --mint-bg:     rgba(255,188,82,0.08);
        --mint-border: rgba(255,188,82,0.2);
        --gold:        #FFE566;
        --dark:        #130D06;
        --surface:     #1E160A;
        --surface2:    #2C1F0E;
        --border:      #4A3218;
        --text:        #F5E8D0;
        --muted:       #9E7A50;
        --text-muted:  #9E7A50;
        --nav-bg:      rgba(19,13,6,0.96);
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--dark);
        color: var(--text);
        font-family: var(--font);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        transition: background 0.3s, color 0.3s;
      }

      /* Grain texture */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.04;
        background-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='300' height='300'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/></filter><rect width='300' height='300' filter='url(%23n)'/></svg>");
        background-repeat: repeat;
        background-size: 300px 300px;
      }

      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0 1.5rem;
        height: 58px;
        background: var(--nav-bg);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--border);
      }

      .wordmark {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--gold);
        text-decoration: none;
        letter-spacing: -0.02em;
        flex-shrink: 0;
      }

      .wordmark-logo {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .nav-spacer { flex: 1; }

      /* Mode switcher */
      .theme-switcher {
        display: flex;
        align-items: center;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 3px;
        gap: 2px;
        flex-shrink: 0;
      }

      .mode-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.18rem 0.48rem;
        border-radius: 999px;
        font-size: 0.95rem;
        line-height: 1;
        transition: background 0.18s, opacity 0.18s;
        opacity: 0.45;
        font-family: var(--font);
      }
      .mode-btn:hover { opacity: 0.8; background: rgba(255,255,255,0.07); }
      .mode-btn.active { background: var(--green); opacity: 1; }

      .balance-pill {
        color: var(--mint);
        font-weight: 600;
        font-size: 0.9rem;
        background: var(--mint-bg);
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        border: 1px solid var(--mint-border);
        white-space: nowrap;
      }

      .btn-more {
        background: var(--green);
        color: #fff;
        border: none;
        padding: 0.38rem 0.8rem;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.18s;
        white-space: nowrap;
        font-family: var(--font);
      }
      .btn-more:hover { background: var(--green-hover); }

      .btn-logout {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        padding: 0.35rem;
        border-radius: 6px;
        display: flex;
        align-items: center;
        transition: color 0.18s;
        flex-shrink: 0;
      }
      .btn-logout:hover { color: var(--text); }

      /* Main content */
      .main-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 1.75rem 1.5rem 5rem;
      }

      @media (max-width: 600px) {
        .nav { padding: 0 1rem; gap: 0.5rem; }
        .btn-more { font-size: 0.72rem; padding: 0.32rem 0.6rem; }
        .main-wrap { padding: 1.25rem 1rem 5rem; }
        .mode-btn { padding: 0.15rem 0.35rem; font-size: 0.82rem; }
      }
    </style>
  </head>
  <body>
    {showNav && (
      <nav class="nav">
        <a href="/" class="wordmark" id="wordmark">
          <img src="/favicon.svg" class="wordmark-logo" alt="Nova" />
          <span id="wordmark-text">NovaBets</span>
        </a>
        <div class="nav-spacer"></div>
        <div class="theme-switcher" id="themeSwitcher">
          <button class="mode-btn" data-mode="standard" title="Standard-tilstand">⚽</button>
          <button class="mode-btn" data-mode="torben" title="Torben-tilstand">🇩🇰</button>
          <button class="mode-btn" data-mode="nova" title="Nova-tilstand">🐕</button>
        </div>
        <span class="balance-pill" id="navBalance">–</span>
        <button class="btn-more" id="btnMore">Få 10.000 kr mere</button>
        <button class="btn-logout" id="btnLogout" title="Log ud" aria-label="Log ud">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        </button>
      </nav>
    )}
    {fullHeight ? <slot /> : <div class="main-wrap"><slot /></div>}

    <script is:inline>
      (function () {
        var MODES = {
          standard: { wordmark: 'NovaBets',     btnMore: 'Få 10.000 kr mere'       },
          torben:   { wordmark: 'NovaBets 🇩🇰', btnMore: 'Mere penge, Torben! 💸'  },
          nova:     { wordmark: 'NovaBets 🐕',   btnMore: 'Snup en godbid 🦴'       }
        };

        function applyMode(mode) {
          document.documentElement.setAttribute('data-theme', mode);
          localStorage.setItem('nb_theme', mode);
          var m = MODES[mode] || MODES.standard;
          var wm = document.getElementById('wordmark-text');
          var bm = document.getElementById('btnMore');
          if (wm) wm.textContent = m.wordmark;
          if (bm) bm.textContent = m.btnMore;
          document.querySelectorAll('.mode-btn').forEach(function (btn) {
            btn.classList.toggle('active', btn.getAttribute('data-mode') === mode);
          });
        }

        applyMode(localStorage.getItem('nb_theme') || 'standard');

        document.querySelectorAll('.mode-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            applyMode(btn.getAttribute('data-mode'));
          });
        });

        function fmtKr(n) {
          return new Intl.NumberFormat('da-DK').format(Math.round(n)) + ' kr';
        }
        function refreshBalance() {
          var raw = localStorage.getItem('nb_balance');
          if (raw === null) { raw = '10000'; localStorage.setItem('nb_balance', raw); }
          var el = document.getElementById('navBalance');
          if (el) el.textContent = fmtKr(parseFloat(raw));
        }
        refreshBalance();
        window.addEventListener('nb_balance_updated', refreshBalance);

        var btnMore = document.getElementById('btnMore');
        if (btnMore) {
          btnMore.addEventListener('click', function () {
            var bal = parseFloat(localStorage.getItem('nb_balance') || '0');
            localStorage.setItem('nb_balance', String(bal + 10000));
            window.dispatchEvent(new Event('nb_balance_updated'));
          });
        }

        var btnLogout = document.getElementById('btnLogout');
        if (btnLogout) {
          btnLogout.addEventListener('click', function () {
            localStorage.removeItem('nb_auth');
            window.location.href = '/login';
          });
        }
      })();
    </script>
  </body>
</html>
